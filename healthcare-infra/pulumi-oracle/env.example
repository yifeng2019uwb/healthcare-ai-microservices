# Oracle Cloud Infrastructure — Pulumi stack config
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit credentials.
#
# How to find each value:
#   OCI_USER_OCID        — OCI Console → top-right profile → User Settings → OCID
#   OCI_FINGERPRINT      — OCI Console → User Settings → API Keys → fingerprint column
#   OCI_TENANCY_OCID     — OCI Console → Governance → Tenancy details → OCID
#   OCI_REGION           — your home region, e.g. us-ashburn-1
#   OCI_KEY_FILE         — full path to the PEM private key you downloaded when creating the API key
#
#   COMPARTMENT_ID       — same as OCI_TENANCY_OCID to deploy in root compartment
#                          (or use a sub-compartment OCID if preferred)
#   AVAILABILITY_DOMAIN  — OCI Console → Compute → Instances → Create instance → Placement field
#                          e.g. abcd:US-ASHBURN-AD-1
#   UBUNTU_IMAGE_ID      — not needed; Pulumi looks up Oracle Linux 9 automatically
#   SSH_PUBLIC_KEY_FILE  — path to your SSH public key file, e.g. ~/.ssh/oracle_vm.pub

# =============================================================================
# OCI provider credentials  →  written to ~/.oci/config by setup.sh
# =============================================================================
OCI_USER_OCID=ocid1.user.oc1..
OCI_FINGERPRINT=
OCI_TENANCY_OCID=ocid1.tenancy.oc1..
OCI_REGION=us-ashburn-1
OCI_KEY_FILE=~/.oci/oci_api_key.pem

# =============================================================================
# Pulumi stack config  →  set via pulumi config set by setup.sh
# =============================================================================
COMPARTMENT_ID=ocid1.tenancy.oc1..
AVAILABILITY_DOMAIN=
SSH_PUBLIC_KEY_FILE=~/.ssh/oracle_vm.pub
VM_CONSOLE_PASSWORD=
