# =============================================================================
# Healthcare AI Platform — .gitignore
# =============================================================================

# Java / Maven
*.class
*.jar
*.war
*.ear
target/
.mvn/wrapper/maven-wrapper.jar
.m2/settings.xml
.m2/settings-security.xml

# Node / React
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*

# Spring Boot — env-specific configs (base application.yml is safe)
application-local.yml
application-prod.yml
application-production.yml
application-staging.yml
services/*/src/main/resources/application-*.yml
services/*/src/main/resources/application-*.properties
services/*/src/main/resources/*.env
services/*/src/main/resources/config/

# Terraform — state and secrets
*.tfstate
*.tfstate.*
.terraform/
*.tfvars
*.tfvars.*
!*.tfvars.example

# Docker
docker/patient/
docker-compose.yml
docker-compose.*.yml
!docker-compose.example.yml

# GCP credentials
*.json
!package.json
!package-lock.json
!**/test-fixtures/*.json
service-account*.json

# Secrets and credentials
secrets/
credentials/
*.pem
*.key
*.crt
*.keystore
*.truststore
*.jks
*.secret
*.credential
*password*.txt
*secret*.txt
.env
*/.env

# Infrastructure config dirs
healthcare-infra/config/
healthcare-infra/terraform/supabase/config/

# Synthea generated data
data/synthea/output/

# Local notes
SETUP_NOTES.md
docs/knowledge-notes/
docs/backup/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
logs/
*.log
*.tmp
*.temp

# Gradle
.gradle/
**/.gradle/
gradle-app.setting

# GitHub Actions local
.secrets
.actrc

# Kubernetes
*.kubeconfig