# Copy this file to .env and fill in your values.
# .env is gitignored — never commit credentials.
#
# Usage: dev.sh loads .env automatically before any Maven command.

# =============================================================================
# PostgreSQL — Supabase cloud
# =============================================================================
SPRING_DATASOURCE_URL=jdbc:postgresql://db.<your-ref>.supabase.co:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=

# =============================================================================
# JWT keys — required by auth-service and all services that validate tokens
# =============================================================================
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_KEY_ID=auth-key-v1
