# Healthcare AI Microservices — Local Development
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit credentials.

# =============================================================================
# PostgreSQL — Supabase (quote the URL to protect & characters)
# =============================================================================
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0
SPRING_DATASOURCE_USERNAME=postgres.<project-ref>
SPRING_DATASOURCE_PASSWORD=

# =============================================================================
# JWT keys — auth-service (signing) and gateway (verification)
# Store as single-line base64 — no headers, no newlines.
#
# Generate a fresh pair for local dev:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out /tmp/jwt_private.pem
#   openssl rsa -in /tmp/jwt_private.pem -pubout -out /tmp/jwt_public.pem
#   grep -v "BEGIN\|END" /tmp/jwt_private.pem | tr -d '\n'   # paste as JWT_PRIVATE_KEY
#   grep -v "BEGIN\|END" /tmp/jwt_public.pem  | tr -d '\n'   # paste as JWT_PUBLIC_KEY
# =============================================================================
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_KEY_ID=auth-key-v1
